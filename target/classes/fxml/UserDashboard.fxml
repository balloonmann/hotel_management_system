<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane styleClass="root" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.controllers.UserController">

    <!-- Top: MenuBar + Header -->
    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Export Invoice" onAction="#handleExportInvoice"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Logout" onAction="#handleLogout"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#handleAbout"/>
                </Menu>
            </MenuBar>
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
                <Label text="Guest Portal" styleClass="label-header"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="seasonInfoLabel" styleClass="season-label"/>
                <Label fx:id="clockLabel" styleClass="clock-label"/>
            </HBox>
        </VBox>
    </top>

    <!-- Left: Sidebar -->
    <left>
        <VBox prefWidth="280" spacing="10" styleClass="sidebar" BorderPane.alignment="TOP_LEFT">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <BorderPane.margin>
                <Insets top="10" right="0" bottom="10" left="10"/>
            </BorderPane.margin>

            <Label styleClass="label-section" text="Search Rooms"/>
            <Separator/>

            <Label text="Room Type:"/>
            <ComboBox fx:id="typeFilter" maxWidth="Infinity">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="All"/>
                        <String fx:value="Standard"/>
                        <String fx:value="Deluxe"/>
                        <String fx:value="Luxury"/>
                    </FXCollections>
                </items>
            </ComboBox>

            <Label text="Max Price/Night (&#x20B9;):"/>
            <TextField fx:id="priceFilter" promptText="Leave empty for any"/>

            <Button maxWidth="Infinity" onAction="#handleViewAvailableRooms" text="Search Rooms" styleClass="btn-info"/>

            <Separator/>
            <Label styleClass="label-section" text="Book a Room"/>

            <TextField fx:id="guestNameField" promptText="Guest Name"/>
            <TextField fx:id="guestContactField" promptText="Contact Number"/>
            <TextField fx:id="roomToBookField" promptText="Room No. (or click table row)"/>

            <Label text="Check-in:"/>
            <DatePicker fx:id="checkInPicker" maxWidth="Infinity"/>

            <Label text="Check-out:"/>
            <DatePicker fx:id="checkOutPicker" maxWidth="Infinity"/>

            <Button maxWidth="Infinity" onAction="#handleBooking" text="Confirm Booking" styleClass="btn-success"/>
            <Button maxWidth="Infinity" onAction="#handleCheckout" text="Checkout Room" styleClass="btn-warning"/>
        </VBox>
    </left>

    <!-- Center: TableView -->
    <center>
        <VBox spacing="10" BorderPane.alignment="TOP_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label styleClass="label-header" text="Available Rooms"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="roomSearchField" promptText="Filter rooms..." prefWidth="200"/>
            </HBox>
            <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colRoomNo" text="Room No." prefWidth="100"/>
                    <TableColumn fx:id="colRoomType" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="colPrice" text="Price/Night" prefWidth="130"/>
                    <TableColumn fx:id="colAmenities" text="Amenities" prefWidth="300"/>
                </columns>
            </TableView>
            <Label fx:id="statusLabel" wrapText="true"/>
        </VBox>
    </center>

</BorderPane>
